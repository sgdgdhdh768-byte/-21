local function createSlider(parent, yPos, label, minVal, maxVal, default, callback)
	local row = Instance.new("Frame")
	row.Size = UDim2.new(0, 260, 0, 50)
	row.Position = UDim2.new(0, 10, 0, yPos)
	row.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	row.BorderSizePixel = 0
	row.Parent = parent

	local rowCorner = Instance.new("UICorner")
	rowCorner.CornerRadius = UDim.new(0, 4)
	rowCorner.Parent = row

	local lbl = Instance.new("TextLabel")
	lbl.BackgroundTransparency = 1
	lbl.Size = UDim2.new(0, 150, 0, 16)
	lbl.Position = UDim2.new(0, 8, 0, 5)
	lbl.Font = Enum.Font.GothamBold
	lbl.TextSize = 11
	lbl.TextColor3 = Color3.fromRGB(220, 220, 220)
	lbl.TextXAlignment = Enum.TextXAlignment.Left
	lbl.Text = label
	lbl.Parent = row

	local val = Instance.new("TextLabel")
	val.BackgroundTransparency = 1
	val.Size = UDim2.new(0, 80, 0, 16)
	val.Position = UDim2.new(1, -88, 0, 5)
	val.Font = Enum.Font.Gotham
	val.TextSize = 11
	val.TextColor3 = Color3.fromRGB(140, 140, 140)
	val.TextXAlignment = Enum.TextXAlignment.Right
	val.Text = tostring(default)
	val.Parent = row

	local sliderBg = Instance.new("TextButton")
	sliderBg.Size = UDim2.new(0, 244, 0, 6)
	sliderBg.Position = UDim2.new(0, 8, 0, 28)
	sliderBg.BackgroundColor3 = Color3.fromRGB(45, 47, 56)
	sliderBg.BorderSizePixel = 0
	sliderBg.Text = ""
	sliderBg.AutoButtonColor = false
	sliderBg.Parent = row

	local sliderCorner = Instance.new("UICorner")
	sliderCorner.CornerRadius = UDim.new(0, 3)
	sliderCorner.Parent = sliderBg

	local fill = Instance.new("Frame")
	fill.Size = UDim2.new(0, 0, 1, 0)
	fill.BackgroundColor3 = Color3.fromRGB(242, 201, 76)
	fill.BorderSizePixel = 0
	fill.Parent = sliderBg

	local fillCorner = Instance.new("UICorner")
	fillCorner.CornerRadius = UDim.new(0, 3)
	fillCorner.Parent = fill

	local knob = Instance.new("TextButton")
	knob.Size = UDim2.new(0, 14, 0, 14)
	knob.Position = UDim2.new(0, -7, 0.5, -7)
	knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	knob.BorderSizePixel = 0
	knob.Text = ""
	knob.AutoButtonColor = false
	knob.ZIndex = 2
	knob.Parent = sliderBg

	local knobCorner = Instance.new("UICorner")
	knobCorner.CornerRadius = UDim.new(0, 7)
	knobCorner.Parent = knob

	local sliderDragging = false

	local function setValue(alpha)
		alpha = math.clamp(alpha, 0, 1)
		local v = math.floor(minVal + (maxVal - minVal) * alpha)
		val.Text = tostring(v)
		fill.Size = UDim2.new(alpha, 0, 1, 0)
		knob.Position = UDim2.new(alpha, -7, 0.5, -7)
		callback(v)
	end

	local initialAlpha = (default - minVal) / (maxVal - minVal)
	setValue(initialAlpha)

	sliderBg.MouseButton1Down:Connect(function()
		sliderDragging = true
		local relX = UserInputService:GetMouseLocation().X - sliderBg.AbsolutePosition.X
		setValue(relX / sliderBg.AbsoluteSize.X)
	end)

	knob.MouseButton1Down:Connect(function()
		sliderDragging = true
	end)

	UserInputService.InputChanged:Connect(function(input)
		if sliderDragging and (input.UserInputType == Enum.UserInputType.MouseMovement) then
			local relX = input.Position.X - sliderBg.AbsolutePosition.X
			setValue(relX / sliderBg.AbsoluteSize.X)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			sliderDragging = false
		end
	end)

	return row
end

