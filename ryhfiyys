	resizing = true
	resizeStart = UserInputService:GetMouseLocation()
	startHeight = MainFrame.AbsoluteSize.Y
end)

UserInputService.InputChanged:Connect(function(input)
	if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement) then
		local deltaY = input.Position.Y - resizeStart.Y
		local newHeight = math.clamp(startHeight + deltaY, MIN_HEIGHT, MAX_HEIGHT)
		MainFrame.Size = UDim2.new(0, 300, 0, newHeight)
		TabContent.Size = UDim2.new(0, 280, 0, newHeight - 80)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		resizing = false
	end
end)

